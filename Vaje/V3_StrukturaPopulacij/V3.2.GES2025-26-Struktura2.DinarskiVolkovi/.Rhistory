library(adegenet)
library(spdep)
DinaricWolves.Metadata = read.table("DinaricWolves.Metadata.txt", header=T, stringsAsFactors = T)
DinaricWolves.Genotypes = read.table("DinaricWolves.Genotypes.txt", header=T, stringsAsFactors = T)
#še nekaj funkcij iz domače kuhinje, ki jih bomo potrebovali
source("Functions_WolfHybridizationStructure.R")
View(DinaricWolves.Genotypes)
DinaricWolves=df2genind(DinaricWolves.Genotypes,sep=" ",ind.names=DinaricWolves.Metadata$AnimalID)
other(DinaricWolves)=list(metadata=DinaricWolves.Metadata[,1:19],xy=DinaricWolves.Metadata[,20:21])
wolves.smry=summary(DinaricWolves)#povzetek podatkov
#spet pogledamo razliko med opaženo in pričakovano heterozigotnostjo.
plot(wolves.smry$Hobs, wolves.smry$Hexp, xlab="Hobs",ylab="Hexp", main="Opažena/Pričakovana Heterozigotnost",xlim=c(0.4,1),ylim=c(0.4,1))
abline(0,1,col="red")
library(adegenet)
library(spdep)
DinaricWolves.Metadata = read.table("DinaricWolves.Metadata.txt", header=T, stringsAsFactors = T)
DinaricWolves.Genotypes = read.table("DinaricWolves.Genotypes.txt", header=T, stringsAsFactors = T)
#še nekaj funkcij iz domače kuhinje, ki jih bomo potrebovali
source("Functions_WolfHybridizationStructure.R")
